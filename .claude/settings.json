{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "swift format format --in-place --recursive Sources Tests Package.swift",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/remote_session_start.sh",
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ]
  }
}